{
  "datasets": [
    {
      "name": "3f5450e6",
      "displayName": "spotify_transformed",
      "queryLines": [
        "SELECT (*) FROM catalog_au.silver.spotify_transformed"
      ]
    },
    {
      "name": "ff1cb990",
      "displayName": "Top 20 Canciones",
      "queryLines": [
        "SELECT\r\n",
        "    track_name,\r\n",
        "    artist_name,\r\n",
        "    ROUND(streams, 2) AS streams_billions\r\n",
        "FROM catalog_au.silver.spotify_transformed\r\n",
        "ORDER BY streams DESC\r\n",
        "LIMIT 20;"
      ]
    },
    {
      "name": "4a354223",
      "displayName": "Top 10 Artistas",
      "queryLines": [
        "SELECT\r\n",
        "    artist_name,\r\n",
        "    COUNT(*)               AS apariciones,\r\n",
        "    ROUND(SUM(streams), 2) AS total_streams\r\n",
        "FROM catalog_au.silver.spotify_transformed\r\n",
        "GROUP BY artist_name\r\n",
        "ORDER BY total_streams DESC\r\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "b31ee6c7",
      "displayName": "Explicitas vs No Explicitas",
      "queryLines": [
        "SELECT\r\n",
        "    CASE WHEN explicit = true THEN 'Explicita' ELSE 'No Explicita' END AS tipo,\r\n",
        "    COUNT(*) AS total_canciones\r\n",
        "FROM catalog_au.silver.spotify_transformed\r\n",
        "GROUP BY explicit;"
      ]
    },
    {
      "name": "a5fd4897",
      "displayName": "Distribucion por Popularidad",
      "queryLines": [
        "SELECT\r\n",
        "    popularity_category,\r\n",
        "    COUNT(*) AS total_canciones\r\n",
        "FROM catalog_au.silver.spotify_transformed\r\n",
        "GROUP BY popularity_category;"
      ]
    },
    {
      "name": "ab8db3a6",
      "displayName": "Major Market vs Global Market",
      "queryLines": [
        "SELECT\r\n",
        "    market_type,\r\n",
        "    ROUND(AVG(streams), 2) AS avg_streams,\r\n",
        "    COUNT(*)               AS total_tracks\r\n",
        "FROM catalog_au.silver.spotify_transformed\r\n",
        "GROUP BY market_type;"
      ]
    },
    {
      "name": "8b76620e",
      "displayName": "Energia vs Danceability",
      "queryLines": [
        "SELECT\r\n",
        "    track_name,\r\n",
        "    artist_name,\r\n",
        "    ROUND(danceability, 2) AS danceability,\r\n",
        "    ROUND(energy, 2)       AS energy,\r\n",
        "    ROUND(streams, 2)      AS streams\r\n",
        "FROM catalog_au.silver.spotify_transformed\r\n",
        "ORDER BY streams DESC\r\n",
        "LIMIT 20;"
      ]
    },
    {
      "name": "799bc215",
      "displayName": "Summary of Spotify Streams and Country Stats",
      "queryLines": [
        "SELECT\r\n",
        "    COUNT(*)                    AS total_canciones,\r\n",
        "    MAX(streams)                AS max_streams,\r\n",
        "    ROUND(AVG(streams), 2)      AS promedio_streams,\r\n",
        "    COUNT(DISTINCT country)     AS total_paises\r\n",
        "FROM catalog_au.silver.spotify_transformed;"
      ]
    },
    {
      "name": "edc240ac",
      "displayName": "Spotify Stream Statistics Overview",
      "queryLines": [
        "SELECT DISTINCT market_type, country\r\n",
        "FROM catalog_au.silver.spotify_transformed\r\n",
        "ORDER BY market_type"
      ]
    }
  ],
